<!doctype html>
<html lang="{{ lang or site.lang or 'en' }}">

  {% include "head.njk" %}

  <body>
    <div class="site-container">
      <div class="site-grid">
      {% include "header.njk" %}
      <main class="content">
        <article class="h-entry inner-grid single-post">
          <header>
            <h1 class="p-name">{{ title }}</h1>
          </header>
          <time class="postlist-date" datetime="{{ post.date | htmlDateString }}">
            {{ post.date | readableDate("LLLL yyyy") }}
          </time>
          
          <div class="content-wrap e-content fluid-type">
            <p class="h4 lede p-summary">{{ meta.desc }}</p>
            {{ content | safe }}
          </div>
        </article>
      </main>

      {% include "footer.njk" %}
    </div>
  </div>
  {% getBundle "fontawesome" %}
  </body>
</html>
